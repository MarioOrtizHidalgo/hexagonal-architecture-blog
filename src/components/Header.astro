---
import Logo from '../assets/logo.svg';
import GithubLogo from './icons/Github.astro';
---

<header class="py-5 border-b border-neutral-300 sticky top-0 z-50 backdrop-blur-md bg-white/70 transition-all duration-300">
    <nav class="flex justify-between items-center">
        <div class="flex gap-4 items-center justify-center">
            <a href="/" class="flex gap-4 items-center">
                <img 
                    src={Logo.src}
                    alt="Logo de la web"
                    class="size-6"
                >
            
                <span class="text-xs font-semibold">Arquitectura Hexagonal</span>
            </a>
        </div>
        <a href="https://github.com/MarioOrtizHidalgo" target="_blank" class="transition-transform hover:-translate-y-1 duration-300">
            <GithubLogo />
        </a>
    </nav>
</header>